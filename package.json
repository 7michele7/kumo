{
  "name": "kumo-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @cloudflare/kumo-docs-astro build",
    "codegen": "pnpm --filter @cloudflare/kumo-docs-astro codegen:demos && pnpm --filter @cloudflare/kumo codegen",
    "build:all": "pnpm -r build",
    "changeset": "tsx ci/scripts/ensure-changeset-config.ts && changeset",
    "clean": "pnpm -r exec rm -rf dist build .astro .wrangler node_modules",
    "dev": "pnpm codegen && pnpm --filter @cloudflare/kumo-docs-astro dev",
    "format": "vp fmt --write",
    "format:check": "vp fmt --check",
    "lint": "pnpm --filter @cloudflare/kumo lint && vp lint packages/*/src",
    "lockfile-check": "pnpm install --no-frozen-lockfile && git diff --exit-code pnpm-lock.yaml",
    "preview": "pnpm --filter @cloudflare/kumo-docs-astro preview",
    "publish:beta": "bash ci/versioning/publish-beta.sh",
    "deploy:kumo-docs-preview": "bash ci/versioning/deploy-kumo-docs-preview.sh",
    "deploy:kumo-docs-staging": "bash ci/versioning/deploy-kumo-docs-staging.sh",
    "ci:post-pr-report": "tsx ci/scripts/post-pr-report.ts",
    "release": "pnpm build:all && changeset publish",
    "release:beta": "changeset publish --no-git-tag --tag beta",
    "release:production": "bash ci/versioning/release-production.sh",
    "kumo": "node packages/kumo/dist/command-line/cli.js",
    "test": "pnpm --filter @cloudflare/kumo test",
    "test:watch": "pnpm --filter @cloudflare/kumo test:watch",
    "typecheck": "pnpm -r typecheck",
    "version": "changeset version",
    "version:beta": "./ci/versioning/version-beta.sh"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.7",
    "@octokit/rest": "22.0.1",
    "@oxlint/plugins": "catalog:",
    "@types/node": "catalog:",
    "@types/pngjs": "^6.0.5",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "onFail": "warn",
      "version": ">=10.21.0"
    },
    "runtime": {
      "name": "node",
      "version": "^24.12.0"
    }
  },
  "engines": {
    "node": "^24.12.0",
    "pnpm": ">=10.21.0"
  },
  "packageManager": "pnpm@10.22.0"
}
